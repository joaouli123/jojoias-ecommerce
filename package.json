{
  "name": "ecommerce",
  "version": "0.1.0",
  "private": true,
  "browserslist": {
    "production": [
      "chrome >= 111",
      "edge >= 111",
      "firefox >= 111",
      "safari >= 16.4",
      "ios_saf >= 16.4"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "dev": "npm run dev:reset",
    "dev:raw": "next dev --webpack",
    "dev:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-reset.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test tests/admin-permissions.test.ts tests/admin-audit.test.ts tests/shipping.test.ts tests/health.test.ts tests/coupons.test.ts tests/validators.test.ts tests/system-events.test.ts tests/catalog-facets.test.ts tests/search-ranking.test.ts tests/blog.test.ts",
    "images:audit": "tsx scripts/audit-images.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "seo:products": "tsx scripts/backfill-product-seo.ts",
    "admin:ensure": "tsx scripts/ensure-admin.ts",
    "coupon:ensure": "tsx scripts/ensure-default-coupon.ts",
    "ga4:ensure": "tsx scripts/ensure-ga4.ts",
    "seed:demo": "tsx scripts/seed-demo-catalog.ts",
    "import:luna:pilot": "tsx scripts/import-luna-pilot.ts",
    "import:luna:all": "tsx scripts/import-luna-pilot.ts",
    "import:rdcarvalho": "tsx scripts/import-rd-carvalho.ts",
    "import:dmanu": "tsx scripts/import-dmanu.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.2",
    "@sentry/nextjs": "^10.43.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.4",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "simple-icons": "^16.10.0",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.18.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
